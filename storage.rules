rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── NOTICE ATTACHMENTS ───────────────────────────────────────────────────
    // Only signed-in admin can upload/delete notice files
    // Anyone can read (download) them (public notice board links)
    match /notices/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── COMPLAINT ATTACHMENTS ────────────────────────────────────────────────
    // Anyone can upload (public complaint form)
    // Only signed-in admin can read/delete
    match /complaints/{allPaths=**} {
      allow create: if true
        && request.resource.size < 15 * 1024 * 1024; // max 15 MB per file
      allow read, delete: if request.auth != null;
    }

    // ── DENY EVERYTHING ELSE ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
